# Build output
/build/
/build-*/
/cmake-build-*/
/out/
*.o
*.obj
*.a
*.lib
*.dylib
*.so
*.dll
*.exe

# Plugin bundles (built artifacts)
*.vst3
*.component
*.clap
*.aaxplugin

# JUCE / CMake fetched deps
/JUCE/
/_deps/
/CMakeFiles/
CMakeCache.txt
cmake_install.cmake

# IDEs
.idea/
.vscode/
*.xcodeproj/
*.xcworkspace/
.cache/

# macOS
.DS_Store

# Signing / secrets — NEVER commit
*.p12
*.cer
*.provisionprofile
*.entitlements.local
notarize-credentials*
.env

# Local AI-assistant brain — kept private/local, not shipped in the public repo
CLAUDE.md
.claude/

# Preamp/poweramp NAM captures: ignore models dropped into these folders; ship the author's V4KR set.
resources/poweramps/*.nam
resources/preamps/*.nam
!resources/preamps/V4KR-*.nam

# Stray build/tool logs
*.log

# local incremental build counter (per-checkout, dev-only — see cmake/bump_build.cmake)
.orbitcab_build_number
