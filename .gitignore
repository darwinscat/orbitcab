# Build output
/build/
/build-*/
/cmake-build-*/
/out/
*.o
*.obj
*.a
*.lib
*.dylib
*.so
*.dll
*.exe

# Plugin bundles (built artifacts)
*.vst3
*.component
*.clap
*.aaxplugin

# JUCE / CMake fetched deps
/JUCE/
/_deps/
/CMakeFiles/
CMakeCache.txt
cmake_install.cmake

# IDEs
.idea/
.vscode/
*.xcodeproj/
*.xcworkspace/
.cache/

# macOS
.DS_Store

# Signing / secrets — NEVER commit
*.p12
*.cer
*.provisionprofile
*.entitlements.local
notarize-credentials*
.env

# Local AI-assistant brain — kept private/local, not shipped in the public repo
CLAUDE.md
.claude/

# Preamp NAM captures — resources/preamps/ is the SHIPPED factory set (fully tracked). Drop private or
# experimental captures into resources/preamps-local/ instead: CMake still embeds them on a local build,
# but they're gitignored, so they're never committed / shipped.
resources/preamps-local/*.nam
resources/poweramps/*.nam

# Stray build/tool logs
*.log

# local incremental build counter (per-checkout, dev-only — see cmake/bump_build.cmake)
.orbitcab_build_number
